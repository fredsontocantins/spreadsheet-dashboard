{
  "buildCommand": "echo 'Static build - no build needed'",
  "installCommand": "echo 'No deps install needed'",
  "framework": null,
  "outputDirectory": "public/dist",
  "regions": ["gru1"],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }] }
  ]
}
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "max-age=0, must-revalidate" }
      ]
    }
  ]
}
