{
  "name": "data-dashboard",
  "version": "1.0.0",
  "description": "Dashboard para leitura e tratamento de planilhas e PDFs",
  "type": "module",
  "scripts": {
    "build": "cd data-dashboard && npx vite build",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "vercel-build": "npm run build && cp -r data-dashboard/dist public"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "^4.0.379",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21"
  }
}
