{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "regions": ["gru1"],
  "experimental": {
    "newElasticsearchScaling": false
  },
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "max-age=0, must-revalidate" }
      ]
    }
  ]
}
